# =============================================================================
# FlowChart AI — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (development) and set the values below.
# Variables are grouped as REQUIRED (app will not function without them) and
# OPTIONAL (feature-specific). Keys are derived from actual `process.env`
# usage in the codebase.
#
#   cp .env.example .env.local
# =============================================================================


# -----------------------------------------------------------------------------
# Core (REQUIRED)
# -----------------------------------------------------------------------------

# Public base URL of the deployment. Used by Better Auth, OAuth callbacks,
# email links, and OpenRouter referer. No trailing slash.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Postgres connection string (Supabase / Neon / self-hosted Postgres).
# For Supabase use the "Session pooler" / direct connection string.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Better Auth signing secret. Generate with: `openssl rand -base64 32`
# (Code reads AUTH_SECRET; Better Auth also accepts BETTER_AUTH_SECRET.)
AUTH_SECRET="replace-with-openssl-rand-base64-32"


# -----------------------------------------------------------------------------
# AI generation (REQUIRED for the core flowchart feature)
# -----------------------------------------------------------------------------
# Get a key at https://openrouter.ai/. Models are set in src/lib/ai-models.ts —
# verify the configured model slugs exist on OpenRouter before going live.
OPENROUTER_API_KEY="sk-or-..."


# -----------------------------------------------------------------------------
# Authentication — Social login (OPTIONAL but recommended)
# -----------------------------------------------------------------------------
# Email/password login works without these, but requires email delivery
# (Resend, below) because email verification is enforced.
#
# Google OAuth — https://console.cloud.google.com/
# Redirect URI: <NEXT_PUBLIC_BASE_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Exposed to the client for Google One Tap (optional).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: <NEXT_PUBLIC_BASE_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# Email — Resend (REQUIRED if you allow email/password sign-up)
# -----------------------------------------------------------------------------
# Email verification is enforced (requireEmailVerification: true), and password
# reset + sign-in OTP all send mail. Without this, email/password sign-up is
# unusable (OAuth-only would still work). https://resend.com/
RESEND_API_KEY=""
# Optional: auto-subscribe new users to a Resend audience/newsletter.
RESEND_AUDIENCE_ID=""


# -----------------------------------------------------------------------------
# Object storage — S3 / Cloudflare R2 (REQUIRED for image-to-flowchart & uploads)
# -----------------------------------------------------------------------------
# The storage provider throws if invoked without these. Text-to-flowchart works
# without storage; image uploads and thumbnails do not.
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="flowchart-ai"
STORAGE_PUBLIC_URL="https://cdn.yourdomain.com"
# Set to "true" for S3-compatible providers that need path-style addressing.
STORAGE_FORCE_PATH_STYLE="false"


# -----------------------------------------------------------------------------
# Payments — Creem (OPTIONAL — only if you offer paid plans)
# -----------------------------------------------------------------------------
# The app's payment provider is Creem (see src/config/website.tsx).
CREEM_API_KEY=""
CREEM_API_URL="https://api.creem.io"
CREEM_WEBHOOK_SECRET=""
CREEM_SUCCESS_URL=""
CREEM_MODERATION_TIMEOUT_MS=""
NEXT_PUBLIC_CREEM_PRODUCT_ID_HOBBY_MONTHLY=""
NEXT_PUBLIC_CREEM_PRODUCT_ID_HOBBY_YEARLY=""
NEXT_PUBLIC_CREEM_PRODUCT_ID_PROFESSIONAL_MONTHLY=""
NEXT_PUBLIC_CREEM_PRODUCT_ID_PROFESSIONAL_YEARLY=""

# Stripe is referenced by some legacy price config keys but Creem is the active
# provider. Leave blank unless you switch the provider in website.tsx.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=""
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=""


# -----------------------------------------------------------------------------
# Integrations & analytics (ALL OPTIONAL)
# -----------------------------------------------------------------------------
# Notifications
DISCORD_WEBHOOK_URL=""
NEXT_PUBLIC_DISCORD_WIDGET_SERVER_ID=""
NEXT_PUBLIC_DISCORD_WIDGET_CHANNEL_ID=""

# Analytics / marketing (set only the ones you use)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_SCRIPT=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_SCRIPT=""
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=""
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
NEXT_PUBLIC_AHREFS_WEBSITE_ID=""
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=""
NEXT_PUBLIC_DATAFAST_DOMAIN=""
NEXT_PUBLIC_SELINE_TOKEN=""

# Affiliate programs
NEXT_PUBLIC_AFFILIATE_AFFONSO_ID=""
NEXT_PUBLIC_AFFILIATE_PROMOTEKIT_ID=""

# Misc
NEXT_PUBLIC_DEMO_WEBSITE=""
